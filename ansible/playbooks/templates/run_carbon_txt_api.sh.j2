/home/deploy/.cargo/bin/uv tool run \
    --with mysqlclient \
    --with "carbon-txt[all]" \
    --from git+https://github.com/thegreenwebfoundation/carbon-txt-validator@{{ git_branch }} \
    --reinstall \
    carbon-txt serve \
    --django-settings local_config \
    --port {{ api_port }} \
    --host 0.0.0.0 \
    --server granian \
    --migrate
